{
  "name": "grolabs-app",
  "version": "0.1.0",
  "private": true,
  "description": "GroLabs — multi-tenant catalog management admin (Phase 1). Dedicated GroLabs admin, shares design language with GroLabs (D22).",
  "scripts": {
    "dev": "next dev --port 3030",
    "build": "next build",
    "start": "next start --port 3030",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "smoke:calcom": "node scripts/calcom-webhook-smoke.mjs",
    "test:smoke": "playwright test",
    "emulate": "npm run emulate:reset && npm run emulate:teardown && npm run emulate:push && npm run emulate:check",
    "emulate:reset": "node --env-file=.env.local scripts/emulator/reset.mjs",
    "emulate:push": "node scripts/emulator/run.mjs",
    "emulate:check": "node --env-file=.env.local scripts/emulator/check.mjs",
    "emulate:seed": "node --env-file=.env.local scripts/emulator/seed-meili.mjs",
    "emulate:teardown": "node --env-file=.env.local scripts/emulator/seed-meili.mjs --teardown",
    "emulate:phase2": "npm run emulate:reset && npm run emulate:seed && npm run emulate:push:phase2 && npm run emulate:check:phase2",
    "emulate:push:phase2": "node scripts/emulator/run.phase2.mjs",
    "emulate:check:phase2": "EMU_SCENARIO=./scenario.phase2.mjs node --env-file=.env.local scripts/emulator/check.mjs",
    "emulate:demo": "node scripts/emulator/seed-demo.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.98.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.45.0",
    "@swc/helpers": "^0.5.21",
    "@tailwindcss/typography": "^0.5.19",
    "@tiptap/extension-character-count": "^3.23.6",
    "@tiptap/extension-code-block-lowlight": "^3.23.6",
    "@tiptap/extension-highlight": "^3.23.6",
    "@tiptap/extension-image": "^3.23.6",
    "@tiptap/extension-link": "^3.23.6",
    "@tiptap/extension-placeholder": "^3.23.6",
    "@tiptap/extension-table": "^3.23.6",
    "@tiptap/extension-table-cell": "^3.23.6",
    "@tiptap/extension-table-header": "^3.23.6",
    "@tiptap/extension-table-row": "^3.23.6",
    "@tiptap/extension-task-item": "^3.23.6",
    "@tiptap/extension-task-list": "^3.23.6",
    "@tiptap/extension-text-align": "^3.23.6",
    "@tiptap/extension-typography": "^3.23.6",
    "@tiptap/extension-youtube": "^3.23.6",
    "@tiptap/pm": "^3.23.6",
    "@tiptap/react": "^3.23.6",
    "@tiptap/starter-kit": "^3.23.6",
    "@tiptap/suggestion": "^3.23.6",
    "@xyflow/react": "^12.10.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "isomorphic-dompurify": "^3.13.0",
    "lowlight": "^3.3.0",
    "lucide-react": "^1.11.0",
    "meilisearch": "^0.58.0",
    "next": "^15.1.0",
    "next-intl": "^4.9.1",
    "next-themes": "^0.4.6",
    "playwright": "^1.60.0",
    "posthog-node": "^5.35.13",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "replicate": "^1.4.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.9.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.5.0",
    "dotenv": "^16.6.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.6.0",
    "vitest": "^2.1.9"
  }
}
