# Scout — environment variable template.
# Copy to .env.local (gitignored) and fill in real values.

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://ixbbhwtpnebrhquunege.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<paste anon key from Supabase project settings → API>
SUPABASE_SERVICE_ROLE_KEY=<paste service_role key — server only, never ship to browser>

# ── Meilisearch (Stage 0 search infrastructure) ──────────────────────────────
# Per docs/policy/search-foundations.md.
# Host is your Meilisearch Cloud project URL. Master key is generated in the
# Cloud dashboard. Scout's meilisearch-client module bootstraps the search-
# scoped parent API key automatically on first use — no extra env var needed
# for that, and per-tenant tokens are minted on demand.
MEILISEARCH_HOST=https://ms-5a6fa3e472b4-47486.nyc.meilisearch.io
MEILISEARCH_MASTER_KEY=<paste master key from Meilisearch Cloud dashboard>

# ── GLPIM (catalog enrichment service) ───────────────────────────────────────
GLPIM_API_URL=<optional — defaults to internal endpoint when unset>
