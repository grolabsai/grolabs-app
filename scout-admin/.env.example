# =============================================================================
# Scout Admin — local development environment
# =============================================================================
# Copy this file to `.env.local` and fill in the real values.
# Never commit `.env.local`. It's already in `.gitignore`.

# Supabase project URL — the one at the top of the project dashboard
NEXT_PUBLIC_SUPABASE_URL=https://ixbbhwtpnebrhquunege.supabase.co

# Publishable (anon) key — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — SERVER ONLY, bypasses RLS. Used for admin-only flows
# (copy-on-signup, imports, reconciliation). Never ship to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
